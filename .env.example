# Database (leave DB_NAME unset to use SQLite)
DB_NAME=arm_marketplace
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=your-secret-key-here
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Logging (e.g. DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Security (when DEBUG=0)
# Set to 1/true/yes to redirect HTTP to HTTPS
SECURE_SSL_REDIRECT=0

# Email (for notifications)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=noreply@example.com

# Production: set DEBUG=0 and add your deployment host(s)
# ALLOWED_HOSTS=your-backend.onrender.com,api.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# JWT (optional overrides)
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
